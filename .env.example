# LangChain model identifier. Override this for another supported provider.
BIG_BEAR_MODEL=google_genai:gemini-2.5-flash

# Google credentials are read server-side and must never be exposed to Vite.
GOOGLE_GENERATIVE_AI_API_KEY=

BIG_BEAR_DATA_DIR=runtime
BIG_BEAR_MAX_UPLOAD_MB=10
BIG_BEAR_MCP_TIMEOUT_SECONDS=15
LANGSMITH_TRACING=false

